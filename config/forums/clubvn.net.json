{
  "id": "clubvn.net",
  "label": "ClubVN",
  "baseUrl": "https://clubvn.net",
  "composeUrlTemplate": "https://clubvn.net/direct-messages/add?to={recipient}",
  "recipientEncoding": "xenforo-plus",
  "selectors": {
    "title": "input[name='title']",
    "body": "[contenteditable='true']",
    "submit": "button[type='submit']"
  },
  "submitIndex": 2,
  "successUrlIncludes": "/direct-messages/",
  "cooldownErrorIncludes": "You must wait at least",
  "permissionErrorIncludes": "do not have permission",
  "delayMs": {
    "min": 70000,
    "max": 95000
  }
}

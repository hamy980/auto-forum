    "phoneInput": "//*[@id='auth-pages']/div/div[contains(@class,'tabs-container') and contains(@class,'auth-pages__container')]/div[contains(@class,'tabs-tab') and contains(@class,'page-sign') and contains(@class,'active')]/div/div[contains(@class,'input-wrapper')]/div[contains(@class,'input-field') and contains(@class,'input-field-phone')]/div[contains(@class,'input-field-input')]",
    "phoneSubmitButton": "//*[@id='auth-pages']/div/div[contains(@class,'tabs-container') and contains(@class,'auth-pages__container')]/div[contains(@class,'tabs-tab') and contains(@class,'page-sign') and contains(@class,'active')]/div/div[contains(@class,'input-wrapper')]/button[contains(@class,'btn-primary') and contains(@class,'btn-color-primary') and contains(@class,'rp')]/div",
    "codeInput": "//*[@id='auth-pages']/div/div[contains(@class,'tabs-container') and contains(@class,'auth-pages__container')]/div[contains(@class,'tabs-tab') and contains(@class,'page-authCode') and contains(@class,'active')]/div/div[contains(@class,'input-wrapper')]/div/input",
    "twoFaInput": "//*[@id='auth-pages']/div/div[contains(@class,'tabs-container') and contains(@class,'auth-pages__container')]/div[contains(@class,'tabs-tab') and contains(@class,'page-password') and contains(@class,'active')]/div/div[contains(@class,'input-wrapper')]/div/input[contains(@class,'input-field-input') and contains(@class,'is-empty')]",
    "twoFaSubmitButton": "//*[@id='auth-pages']/div/div[contains(@class,'tabs-container') and contains(@class,'auth-pages__container')]/div[contains(@class,'tabs-tab') and contains(@class,'page-password') and contains(@class,'active')]/div/div[contains(@class,'input-wrapper')]/button/div",
    "chatListIndicator": ".chatlist",
    "waitBetweenSteps": { "min": 5000, "max": 10000 }
  },
  "selectors": {
    "searchInput": ".search-input",
